generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Enquiry {
  id        String   @id @default(cuid())
  reference String   @unique
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsArticle {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  summary   String
  body      String
  category  String
  type      String
  size      String
  date      String
  day       String
  month     String
  sourceUrl String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  type      String
  category  String
  summary   String
  sourceUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketSnapshot {
  id        String   @id @default(cuid())
  quotes    String
  source    String
  createdAt DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model GoldDeposit {
  id               String   @id @default(cuid())
  reference        String   @unique
  name             String
  email            String
  phone            String
  amountUsd        Decimal  @db.Decimal(12, 2)
  gramsQuoted      Decimal  @db.Decimal(12, 6)
  spotPricePerG    Decimal  @db.Decimal(12, 4)
  priceLockedUntil DateTime
  paymentMethod    String   @default("usdt")
  status           String   @default("pending_payment")
  txHash           String?
  proofUrl         String?
  adminNotes       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model NetworkMember {
  id                String           @id @default(cuid())
  reference         String           @unique
  companyName       String
  contactName       String
  email             String
  phone             String
  licenseNumber     String?
  location          String
  productType       String
  volumeRange       String
  notes             String?
  status            String           @default("pending")
  verificationLevel Int              @default(0)
  adminNotes        String?
  supply            VerifiedSupply[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model VerifiedSupply {
  id                String            @id @default(cuid())
  reference         String            @unique
  memberId          String
  member            NetworkMember     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  title             String
  productType       String
  purity            String?
  volumeEstimate    String
  location          String
  verificationLevel Int               @default(3)
  assayRef          String?
  status            String            @default("draft")
  summary           String?
  enquiries         ExchangeEnquiry[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model InstitutionalAccount {
  id                  String            @id @default(cuid())
  reference           String            @unique
  companyName         String
  contactName         String
  email               String            @unique
  phone               String?
  country             String?
  buyerType           String
  message             String?
  passwordHash        String?
  status              String            @default("pending")
  membershipTier      String            @default("standard")
  membershipExpiresAt DateTime?
  adminNotes          String?
  enquiries           ExchangeEnquiry[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model ExchangeEnquiry {
  id            String                @id @default(cuid())
  reference     String                @unique
  supplyId      String
  supply        VerifiedSupply        @relation(fields: [supplyId], references: [id], onDelete: Cascade)
  accountId     String?
  account       InstitutionalAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contactName   String
  email         String
  companyName   String?
  message       String
  status        String                @default("new")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}